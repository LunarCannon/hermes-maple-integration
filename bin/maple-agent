#!/usr/bin/env bash
set -euo pipefail

# Keep subprocess output machine-clean when called from gateway slash handlers.
export NO_COLOR=1
export CLICOLOR=0
export TERM=dumb

# Spawn a Hermes agent whose brain is Maple via the maple-private profile.
# Supports one-shot prompts and --resume for stateful Maple thread follow-ups.
# Sources the Maple key from the service env file without printing it.

HERMES_HOME_DIR="${HERMES_HOME:-$HOME/.hermes}"
SECRET_ENV="$HERMES_HOME_DIR/secrets/maple.env"
if [[ -f "$SECRET_ENV" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$SECRET_ENV"
  set +a
fi

usage() {
  cat >&2 <<'USAGE'
Usage:
  maple-agent "prompt"
  maple-agent --file /path/to/input.md --prompt "instruction"
  maple-agent /path/to/task.md
  maple-agent --resume SESSION_ID "follow-up prompt"

Notes:
  - If the first positional argument is an existing file, Maple Hermes is asked
    to read that path with its file tool rather than putting file contents on
    this command line.
  - Uses Hermes profile: maple-private by default.
USAGE
}

file_path=""
prompt=""
model=""
profile="maple-private"
toolsets="file,terminal"
resume_id=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --file|-f)
      [[ $# -ge 2 ]] || { usage; exit 2; }
      file_path="$2"; shift 2 ;;
    --prompt|-p)
      [[ $# -ge 2 ]] || { usage; exit 2; }
      prompt="$2"; shift 2 ;;
    --model|-m)
      [[ $# -ge 2 ]] || { usage; exit 2; }
      model="$2"; shift 2 ;;
    --profile)
      [[ $# -ge 2 ]] || { usage; exit 2; }
      profile="$2"; shift 2 ;;
    --toolsets)
      [[ $# -ge 2 ]] || { usage; exit 2; }
      toolsets="$2"; shift 2 ;;
    --resume|-r)
      [[ $# -ge 2 ]] || { usage; exit 2; }
      resume_id="$2"; shift 2 ;;
    --help|-h)
      usage; exit 0 ;;
    *)
      if [[ -z "$file_path" && -e "$1" && -f "$1" ]]; then
        file_path="$1"
      else
        if [[ -n "$prompt" ]]; then prompt+=" "; fi
        prompt+="$1"
      fi
      shift ;;
  esac
done

if [[ -z "$prompt" && -z "$file_path" ]]; then
  usage
  exit 2
fi

if [[ -n "$file_path" ]]; then
  abs_path="$(python3 - "$file_path" <<'PY'
from pathlib import Path
import sys
print(Path(sys.argv[1]).expanduser().resolve())
PY
)"
  if [[ -z "$prompt" ]]; then
    prompt="Read the local file at ${abs_path} and complete the task described in it. Return the result only."
  else
    prompt="Read the local file at ${abs_path}. ${prompt}"
  fi
fi

cmd=(hermes --profile "$profile")
if [[ -n "$resume_id" ]]; then
  cmd+=(--resume "$resume_id")
fi
cmd+=(chat -q "$prompt" -Q --toolsets "$toolsets")
if [[ -n "$model" ]]; then
  cmd+=(--model "$model")
fi
exec "${cmd[@]}"
